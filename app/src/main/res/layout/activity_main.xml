<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_anime"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Catatan Keuangan"
        android:textSize="25sp"
        android:textStyle="bold"
        android:textColor="@color/anime_text"
        android:gravity="center"
        android:layout_marginTop="18dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kelola pemasukan dan pengeluaran harianmu"
        android:textSize="14sp"
        android:textColor="@color/anime_soft_text"
        android:gravity="center"
        android:layout_marginTop="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_anime"
        android:orientation="vertical"
        android:elevation="6dp"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Saldo Total"
            android:textColor="@color/anime_soft_text"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvSaldo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Rp0"
            android:textColor="@color/anime_purple"
            android:textStyle="bold"
            android:textSize="31sp" />

        <TextView
            android:id="@+id/tvJumlahTransaksi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0 transaksi tersimpan"
            android:textColor="@color/anime_soft_text"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_card_anime"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pemasukan"
                android:textSize="12sp"
                android:textColor="@color/anime_soft_text" />

            <TextView
                android:id="@+id/tvTotalPemasukan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rp0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/income_green" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_card_anime"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pengeluaran"
                android:textSize="12sp"
                android:textColor="@color/anime_soft_text" />

            <TextView
                android:id="@+id/tvTotalPengeluaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rp0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/expense_red" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_card_anime"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grafik Pemasukan vs Pengeluaran"
            android:textColor="@color/anime_text"
            android:textStyle="bold"
            android:textSize="14sp" />

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="match_parent"
            android:layout_height="95dp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTambah"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_button_anime"
            android:text="+ Tambah"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnExportCsv"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_light"
            android:text="Export CSV"
            android:textColor="@color/anime_purple"
            android:textStyle="bold"
            android:textSize="14sp" />

    </LinearLayout>

    <RadioGroup
        android:id="@+id/rgFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbSemua"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Semua"
            android:textSize="12sp"
            android:textColor="@color/anime_text"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbPemasukan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pemasukan"
            android:textSize="12sp"
            android:textColor="@color/anime_text" />

        <RadioButton
            android:id="@+id/rbPengeluaran"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengeluaran"
            android:textSize="12sp"
            android:textColor="@color/anime_text" />

    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Riwayat Transaksi"
        android:textColor="@color/anime_text"
        android:textStyle="bold"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tvKosong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="Belum ada transaksi.\nYuk catat pemasukan atau pengeluaran pertamamu!"
        android:textColor="@color/anime_soft_text"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTransaksi"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1" />

</LinearLayout>