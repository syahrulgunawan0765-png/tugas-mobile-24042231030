<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_anime">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tambah Transaksi"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/anime_text"
            android:gravity="center"
            android:layout_marginTop="28dp" />

        <TextView
            android:id="@+id/tvFormSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Catat pemasukan atau pengeluaranmu"
            android:textSize="14sp"
            android:textColor="@color/anime_soft_text"
            android:gravity="center"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_card_anime"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama Transaksi"
                android:textColor="@color/anime_text"
                android:textStyle="bold"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_anime"
                android:hint="Contoh: Uang jajan"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/anime_text"
                android:textColorHint="@color/anime_soft_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Jumlah"
                android:textColor="@color/anime_text"
                android:textStyle="bold"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etJumlah"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_anime"
                android:hint="Contoh: 50000"
                android:inputType="number"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/anime_text"
                android:textColorHint="@color/anime_soft_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Tipe Transaksi"
                android:textColor="@color/anime_text"
                android:textStyle="bold"
                android:textSize="15sp" />

            <RadioGroup
                android:id="@+id/rgTipe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbPemasukan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pemasukan"
                    android:textColor="@color/anime_text"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbPengeluaran"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengeluaran"
                    android:textColor="@color/anime_text" />

            </RadioGroup>

        </LinearLayout>

        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_anime"
            android:text="Simpan Transaksi"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnBatal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_light"
            android:text="Batal"
            android:textColor="@color/anime_purple"
            android:textStyle="bold"
            android:textSize="15sp" />

    </LinearLayout>

</ScrollView>
